{
  "$schema": "http://json.schemastore.org/template",
  "author": "Fernando Terra",
  "classifications": ["Web", "API", "Arkn"],
  "identity": "Arkn.Templates.Api",
  "name": "Arkn Minimal API",
  "shortName": "arkn-api",
  "description": "A Minimal API starter with Arkn.Results, error→HTTP mapping, global usings and GitHub Actions CI.",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ArknApi",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "Target framework",
      "datatype": "choice",
      "choices": [{ "choice": "net10.0" }],
      "defaultValue": "net10.0"
    }
  }
}
